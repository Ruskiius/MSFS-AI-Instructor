<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
  </PropertyGroup>

  <PropertyGroup>
    <SimConnectSdkRoot Condition="'$(SimConnectSdkRoot)' == '' and '$(MSFS_SDK)' != ''">$(MSFS_SDK)\SimConnect SDK</SimConnectSdkRoot>
    <SimConnectSdkRoot Condition="'$(SimConnectSdkRoot)' == '' and Exists('C:\MSFS SDK\SimConnect SDK')">C:\MSFS SDK\SimConnect SDK</SimConnectSdkRoot>
  </PropertyGroup>

  <ItemGroup Condition="'$(SimConnectSdkRoot)' != '' and Exists('$(SimConnectSdkRoot)\lib\SimConnect.dll')">
    <None Include="$(SimConnectSdkRoot)\lib\SimConnect.dll" Link="SimConnect.dll" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
